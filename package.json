{
	"name": "blog",
	"version": "0.0.2",
	"description": "Personal Blog",
	"author": "Miad Abdi",
	"private": false,
	"license": "MIT",
	"scripts": {
		"minio:down:dev": "sudo docker compose rm minio -f -s -v",
		"minio:up:dev": "sudo docker compose up minio -d",
		"prisma:studio:dev": "npx prisma studio --port 7777",
		"prisma:migrate:deploy": "npx prisma migrate deploy",
		"prisma:migrate:dev": "npx prisma migrate dev",
		"db:seed:dev": "npx prisma db seed",
		"db:rm:dev": "sudo docker compose rm blog-db -f -s -v",
		"db:up:dev": "sudo docker compose up blog-db -d",
		"db:restart:dev": "npm run db:rm:dev && npm run db:up:dev && sleep 5 && npm run prisma:deploy:dev",
		"prisma:deploy:test": "dotenv -e .env.test -- prisma migrate deploy",
		"db:rm:test": "sudo docker compose rm blog-db_test -f -s -v",
		"db:up:test": "sudo docker compose up blog-db_test -d",
		"db:restart:test": "npm run db:rm:test && npm run db:up:test && sleep 5 && npm run prisma:deploy:test",
		"prebuild": "rimraf dist",
		"build": "nest build",
		"prettier": "prettier --ignore-path .gitignore \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint --ignore-path .gitignore \"{src,apps,libs,test}/**/*.ts\" --fix",
		"lint:no-fix": "eslint --ignore-path .gitignore \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"pretest:e2e": "npm run db:restart:test",
		"test:e2e": "dotenv -e .env.test -- jest --config ./test/jest-e2e.json",
		"pretest:e2e:watch": "npm run db:restart:test",
		"test:e2e:watch": "dotenv -e .env.test -- jest --watchAll --no-cache --config ./test/jest-e2e.json",
		"prisma:studio:test": "dotenv -e .env.test -- npx prisma studio --port 7777",
		"prepare": "husky install",
		"check-types": "tsc --dry",
		"format": "npm run prettier --write",
		"check-format": "npm run prettier --list-different",
		"validate": "npm-run-all --parallel check-types check-format lint:no-fix",
		"lint-fix": "eslint --fix 'src/**/*.{js,jsx,ts,tsx,json,css,scss,md}'"
	},
	"prisma": {
		"seed": "ts-node prisma/seed.ts"
	},
	"dependencies": {
		"@casl/ability": "^6.5.0",
		"@casl/prisma": "^1.4.1",
		"@nestjs-modules/mailer": "^1.10.3",
		"@nestjs/common": "^10.3.0",
		"@nestjs/config": "^3.1.1",
		"@nestjs/core": "^10.3.0",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/passport": "^10.0.3",
		"@nestjs/platform-express": "^10.3.0",
		"@nestjs/swagger": "^7.2.0",
		"@nestjs/throttler": "^5.1.1",
		"@prisma/client": "^5.8.1",
		"@types/compression": "^1.7.5",
		"@types/hpp": "^0.2.5",
		"argon2": "^0.31.2",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.1",
		"compression": "^1.7.4",
		"cookie-parser": "^1.4.6",
		"dotenv": "^16.3.1",
		"ejs": "^3.1.9",
		"helmet": "^7.1.0",
		"hpp": "^0.2.3",
		"joi": "^17.12.0",
		"multer": "^1.4.5-lts.1",
		"nest-winston": "^1.9.4",
		"nestjs-minio-client": "^2.2.0",
		"nodemailer": "^6.9.8",
		"passport": "^0.7.0",
		"passport-jwt": "^4.0.1",
		"prisma": "^5.8.1",
		"rimraf": "^5.0.5",
		"rxjs": "^7.8.1",
		"sharp": "^0.33.2",
		"slugify": "^1.6.6",
		"winston": "^3.11.0",
		"winston-daily-rotate-file": "^4.7.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^18.4.4",
		"@commitlint/config-conventional": "^18.4.4",
		"@nestjs/cli": "^10.3.0",
		"@nestjs/schematics": "^10.1.0",
		"@nestjs/testing": "^10.3.0",
		"@types/cookie-parser": "^1.4.6",
		"@types/express": "^4.17.21",
		"@types/jest": "29.5.11",
		"@types/minio": "^7.1.0",
		"@types/multer": "^1.4.11",
		"@types/node": "^20.11.5",
		"@types/nodemailer": "^6.4.14",
		"@types/passport-jwt": "^4.0.0",
		"@types/sharp": "^0.31.1",
		"@types/supertest": "^6.0.2",
		"@typescript-eslint/eslint-plugin": "^6.19.0",
		"@typescript-eslint/parser": "^6.19.0",
		"dotenv-cli": "^7.3.0",
		"eslint": "^8.56.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.1.3",
		"husky": "^8.0.3",
		"jest": "29.7.0",
		"lint-staged": "^15.2.0",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.2.4",
		"source-map-support": "^0.5.21",
		"supertest": "^6.3.4",
		"ts-jest": "29.1.1",
		"ts-loader": "^9.5.1",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "4.2.0",
		"typescript": "^5.3.3"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
