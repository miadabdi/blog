{
	"name": "blog",
	"version": "0.0.2",
	"description": "Personal Blog",
	"author": "Miad Abdi",
	"private": false,
	"license": "MIT",
	"scripts": {
		"prisma:studio:dev": "npx prisma studio --port 7777",
		"prisma:deploy:dev": "prisma migrate deploy",
		"db:rm:dev": "sudo docker compose rm blog-db -f -s -v",
		"db:up:dev": "sudo docker compose up blog-db -d",
		"db:restart:dev": "npm run db:rm:dev && npm run db:up:dev && sleep 5 && npm run prisma:deploy:dev",
		"prisma:deploy:test": "dotenv -e .env.test -- prisma migrate deploy",
		"db:rm:test": "sudo docker compose rm blog-db_test -f -s -v",
		"db:up:test": "sudo docker compose up blog-db_test -d",
		"db:restart:test": "npm run db:rm:test && npm run db:up:test && sleep 5 && npm run prisma:deploy:test",
		"prebuild": "rimraf dist",
		"build": "nest build",
		"prettier": "prettier --ignore-path .gitignore \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint --ignore-path .gitignore \"{src,apps,libs,test}/**/*.ts\" --fix",
		"lint:no-fix": "eslint --ignore-path .gitignore \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"pretest:e2e": "npm run db:restart:test",
		"test:e2e": "dotenv -e .env.test -- jest --config ./test/jest-e2e.json",
		"pretest:e2e:watch": "npm run db:restart:test",
		"test:e2e:watch": "dotenv -e .env.test -- jest --watchAll --no-cache --config ./test/jest-e2e.json",
		"prisma:studio:test": "dotenv -e .env.test -- npx prisma studio --port 7777",
		"prepare": "husky install",
		"check-types": "tsc --dry",
		"format": "npm run prettier --write",
		"check-format": "npm run prettier --list-different",
		"validate": "npm-run-all --parallel check-types check-format lint:no-fix"
	},
	"dependencies": {
		"@nestjs-modules/mailer": "^1.8.1",
		"@nestjs/common": "^9.0.0",
		"@nestjs/config": "^2.2.0",
		"@nestjs/core": "^9.0.0",
		"@nestjs/jwt": "^9.0.0",
		"@nestjs/passport": "^9.0.0",
		"@nestjs/platform-express": "^9.0.0",
		"@nestjs/swagger": "^6.1.2",
		"@nestjs/throttler": "^3.0.0",
		"@prisma/client": "^4.3.1",
		"@types/compression": "^1.7.2",
		"@types/hpp": "^0.2.2",
		"argon2": "^0.29.1",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.13.2",
		"compression": "^1.7.4",
		"cookie-parser": "^1.4.6",
		"dotenv": "^16.0.2",
		"ejs": "^3.1.8",
		"helmet": "^6.0.0",
		"hpp": "^0.2.3",
		"joi": "^17.6.0",
		"nest-winston": "^1.7.0",
		"nodemailer": "^6.7.8",
		"passport": "^0.6.0",
		"passport-jwt": "^4.0.0",
		"reflect-metadata": "^0.1.13",
		"rimraf": "^3.0.2",
		"rxjs": "^7.2.0",
		"winston": "^3.8.2",
		"winston-daily-rotate-file": "^4.7.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^17.1.2",
		"@commitlint/config-conventional": "^17.1.0",
		"@nestjs/cli": "^9.0.0",
		"@nestjs/schematics": "^9.0.0",
		"@nestjs/testing": "^9.0.0",
		"@types/cookie-parser": "^1.4.3",
		"@types/express": "^4.17.13",
		"@types/jest": "28.1.4",
		"@types/node": "^16.11.58",
		"@types/nodemailer": "^6.4.5",
		"@types/passport-jwt": "^3.0.6",
		"@types/supertest": "^2.0.11",
		"@typescript-eslint/eslint-plugin": "^5.0.0",
		"@typescript-eslint/parser": "^5.0.0",
		"dotenv-cli": "^6.0.0",
		"eslint": "^8.0.1",
		"eslint-config-prettier": "^8.3.0",
		"eslint-plugin-prettier": "^4.0.0",
		"husky": "^8.0.0",
		"jest": "28.1.2",
		"npm-run-all": "^4.1.5",
		"prettier": "^2.3.2",
		"source-map-support": "^0.5.20",
		"supertest": "^6.1.3",
		"ts-jest": "28.0.5",
		"ts-loader": "^9.2.3",
		"ts-node": "^10.0.0",
		"tsconfig-paths": "4.0.0",
		"typescript": "^4.3.5"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
